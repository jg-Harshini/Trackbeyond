# Backend Environment Variables Template
# Copy this file to application.properties and fill in your values

# Server Configuration
server.port=8080

# MongoDB Atlas Configuration
# Get your connection string from MongoDB Atlas dashboard
spring.data.mongodb.uri=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
spring.data.mongodb.database=dementia_tracker

# JWT Configuration
# Generate a secure random string for production (at least 256 bits)
jwt.secret=<your_secure_jwt_secret_here>
jwt.expiration=86400000

# CORS Configuration
# Add your frontend URLs (comma-separated)
# In production, this should include your frontend deployment link



